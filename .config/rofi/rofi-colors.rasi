// }
scrollbar {
    width:        0px ;
    border:       0;
    handle-width: 0px ;
    padding:      0;
    margin: 0px;
}
mode-switcher {
    // border-color: @outline;
}
// button.selected {
//     background-color: @selected-normal-background;
//     text-color:       @selected-normal-foreground;
// }
inputbar {
    spacing:    0;
    text-color: @on-primary;
    padding: 0;
    margin: 0;
    border-radius: 2;
}
case-indicator {
    spacing:    0;
    text-color: @on-primary;
}
entry {
    spacing:    0;
    text-color: @on-primary;
    background-color: @secondary;
    padding: 4;
}
prompt {
    spacing:    0;
    text-color: @on-primary;
    background-color: @secondary;
    padding: 4;
}
